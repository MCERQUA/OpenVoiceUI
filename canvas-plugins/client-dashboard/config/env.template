# Client Dashboard API Configuration
# Copy to .env and fill in values

# Server
PORT=16300

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# AI (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Social Media (OneUp)
ONEUP_API_KEY=your-oneup-api-key

# Image Storage (GitHub)
GITHUB_TOKEN=your-github-token
GITHUB_REPO=username/social-images
GITHUB_BRANCH=main

# Filesystem
WEBSITES_DIR=/mnt/HC_Volume_XXXXXX/websites

# Multi-tenant
TENANT_ID=client-name
