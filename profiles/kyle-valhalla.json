{
  "id": "kyle-valhalla",
  "name": "Kyle Valhalla",
  "description": "Voice assistant with Kyle Valhalla cloned voice",
  "version": "1.0",
  "system_prompt": "You ARE Kyle from BigHeads. Stay in character. Slow stoner energy, rambling tangents, confused optimism. Never break character. Never act like an assistant.",
  "adapter": "clawdbot",
  "llm": {
    "provider": "gateway",
    "model": "glm-4.7",
    "parameters": {
      "max_tokens": 256,
      "temperature": 0.8
    },
    "queue": {
      "mode": "steer",
      "block_streaming_chunk": 60,
      "block_streaming_coalesce": false
    }
  },
  "voice": {
    "tts_provider": "resemble",
    "voice_id": "704cb696",
    "speed": 1.0,
    "parameters": {},
    "parallel_sentences": true,
    "min_sentence_chars": 40,
    "inter_sentence_gap_ms": null
  },
  "stt": {
    "provider": "deepgram",
    "language": "en-US",
    "silence_timeout_ms": 3500,
    "continuous": true,
    "wake_words": [
      "wake up"
    ],
    "wake_word_required": null,
    "ptt_default": null
  },
  "context": {
    "enable_fts": true,
    "enable_briefing": false,
    "enable_history": true,
    "max_history_messages": 8
  },
  "features": {
    "canvas": true,
    "vision": true,
    "music": false,
    "tools": true
  },
  "ui": {
    "theme": "dark",
    "theme_preset": "blue",
    "face_enabled": true,
    "face_mode": "halo-smoke",
    "face_mood": "neutral",
    "transcript_panel": true,
    "thought_bubbles": false,
    "show_mode_badge": true,
    "mode_badge_text": "Kyle Valhalla",
    "voice_mode": "supertonic",
    "visualizer_enabled": true,
    "music_autoplay": false
  },
  "conversation": {
    "greeting": null,
    "auto_hangup_silence_ms": null,
    "interruption_enabled": true,
    "max_response_chars": 1500
  },
  "modes": {
    "normal": true,
    "listen": true,
    "ptt": true,
    "a2a": false
  },
  "session": {
    "key_strategy": "persistent",
    "key_prefix": "voice-kyle"
  },
  "auth": {
    "required": null,
    "allowed_roles": null
  },
  "adapter_config": {
    "sessionKey": "voice-kyle-1",
    "agentId": "kyle"
  }
}