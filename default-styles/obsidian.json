    "heading": "#f8fafc",
    "brand": "#3b82f6",
    "brand-contrast": "#ffffff",
    "accent": "#22d3ee",
    "success": "#34d399",
    "warning": "#fbbf24",
    "danger": "#f87171",
    "scrollbar": "#2a3852",
