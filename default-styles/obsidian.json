{
  "id": "obsidian",
  "name": "Obsidian",
  "tagline": "Premium dark glass \u2014 depth you can feel",
  "description": "A refined enterprise-dark system in the spirit of Linear and Vercel: deep blue-slate surfaces, translucent glass cards with hairline gradient borders, ambient blue-cyan glow, and confident 900-weight numerals. Rich, calm, and expensive-looking \u2014 never a hacker terminal.",
  "base": "dark",
  "version": 1,
  "tokens": {
    "bg": "#0b0e16",
    "surface": "#121826",
    "surface-2": "#1a2334",
    "border": "#243048",
