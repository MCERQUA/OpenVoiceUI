{
  "id": "meridian",
  "name": "Meridian",
  "tagline": "Crisp, confident, modern SaaS light",
  "description": "The Linear/Stripe-dashboard aesthetic: white surfaces on cool gray, Inter + Sora type, blue brand, soft layered shadows and generous whitespace. Clean enough to ship as a Fortune-500 product.",
  "base": "light",
  "version": 1,
  "tokens": {
    "bg": "#f8fafc",
    "surface": "#ffffff",
    "surface-2": "#f1f5f9",
    "border": "#e2e8f0",
