    "text-secondary": "#8f939c",
    "text-muted": "#63676f",
    "heading": "#f4f5f7",
    "brand": "#e10600",
    "brand-contrast": "#ffffff",
    "accent": "#c7ccd6",
    "success": "#2fd071",
    "warning": "#ffb020",
    "danger": "#ff453a",
