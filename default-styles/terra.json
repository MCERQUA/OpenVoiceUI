    "text-secondary": "#7a6c5a",
    "text-muted": "#a3927c",
    "heading": "#2e2620",
    "brand": "#c2410c",
    "brand-contrast": "#ffffff",
    "accent": "#5f7a3d",
    "success": "#3f7d4e",
    "warning": "#a16207",
    "danger": "#b3261e",
    "scrollbar": "#d5c7b0",
